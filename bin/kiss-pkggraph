#!/bin/sh

# Usage: kiss-pkggraph <pkg>

seen="$(mktemp)" || exit 1
trap 'rm -f "$seen"' EXIT

pkg="$1"
printf '%s\n' "$pkg" > /dev/null

# queue: newline-separated package names to process
printf '%s\n' "$pkg" > /tmp/kpg_queue_$$

while IFS= read -r curpkg; do
    # skip empty lines
    [ -z "$curpkg" ] && continue
    # skip if already seen
    if grep -xq "$curpkg" "$seen" 2>/dev/null; then
        continue
    fi
    # mark seen
    printf '%s\n' "$curpkg" >> "$seen"

    depsfile="$(kiss search "$curpkg" | sed q)/depends"
    if [ -e "$depsfile" ]; then
        # get first column of depends
        awk '{print $1}' < "$depsfile" | while IFS= read -r dep; do
            [ -z "$dep" ] && continue
            printf '%s %s\n' "$dep" "$curpkg"
            # enqueue dependency for processing
            printf '%s\n' "$dep" >> /tmp/kpg_queue_$$
        done
    fi
done < /tmp/kpg_queue_$$

rm -f /tmp/kpg_queue_$$
